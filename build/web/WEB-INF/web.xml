<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>AnnouncementServlet</servlet-name>
        <servlet-class>com.iforum.controller.AnnouncementServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CheckMatricServlet</servlet-name>
        <servlet-class>com.iforum.controller.CheckMatricServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.iforum.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DiscussionGroupServlet</servlet-name>
        <servlet-class>com.iforum.controller.DiscussionGroupServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>lecturerDashboardServlet</servlet-name>
        <servlet-class>com.iforum.controller.lecturerDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <servlet-class>com.iforum.controller.StudentDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserServlet</servlet-name>
        <servlet-class>com.iforum.controller.UserServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResourcesServlet</servlet-name>
        <servlet-class>com.iforum.controller.ResourcesServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FeedbackServlet</servlet-name>
        <servlet-class>com.iforum.controller.FeedbackServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CoordinatorServlet</servlet-name>
        <servlet-class>com.iforum.controller.CoordinatorDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnnouncementServlet</servlet-name>
        <url-pattern>/AnnouncementServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CheckMatricServlet</servlet-name>
        <url-pattern>/CheckMatricServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DiscussionGroupServlet</servlet-name>
        <url-pattern>/DiscussionGroupServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>lecturerDashboardServlet</servlet-name>
        <url-pattern>/lecturerDashboardServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentDashboardServlet</servlet-name>
        <url-pattern>/StudentDashboardServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserServlet</servlet-name>
        <url-pattern>/UserServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResourcesServlet</servlet-name>
        <url-pattern>/ResourcesServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FeedbackServlet</servlet-name>
        <url-pattern>/FeedbackServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.css</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.js</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.png</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CoordinatorServlet</servlet-name>
        <url-pattern>/CoordinatorServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
